{
  "permissions": {
    "allow": [
      "Bash(npx tsc:*)",
      "Bash(uv run ruff check:*)",
      "Bash(uv run dg check --module-name macro_agents.definitions:*)",
      "Bash(docker compose ps:*)",
      "Bash(docker compose ps -a:*)",
      "Bash(docker compose logs:*)",
      "Bash(docker inspect:*)",
      "Bash(git status:*)",
      "Bash(git branch --show-current)",
      "Bash(git log --oneline:*)",
      "Bash(git diff --stat:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | { read file_path; if echo \"$file_path\" | grep -Eq '\\\\.(ts|tsx|py)$'; then npx tsc --noEmit && uv run ruff check . && cd macro_agents && uv run dg check --module-name macro_agents.definitions; fi; }"
          }
        ]
      }
    ]
  }
}
